---
import heroBgDark from '../../assets/hero-bg-dark.png';
import heroBgLight from '../../assets/hero-bg-light.png';

interface Props {
  label?: string;
  title: string;
  subtitle?: string;
  primaryCTA?: { label: string; href: string };
  secondaryCTA?: { label: string; href: string };
  stats?: { value: string; label: string }[];
}

const {
  label = 'AI-Powered Marketing Architecture',
  title,
  subtitle,
  primaryCTA = { label: 'Get Started', href: '/contact' },
  secondaryCTA = { label: 'See Services', href: '/services' },
  stats,
} = Astro.props;
---

<section class="relative min-h-[90vh] flex items-center overflow-hidden card-glow group" id="hero">
  <!-- Background effects -->
  <div class="absolute inset-0 z-0 pointer-events-none transition-opacity duration-700 w-full h-full">
    <div class="absolute inset-0 bg-no-repeat bg-cover bg-center transition-opacity duration-700 opacity-60 global-dark-bg" style={`background-image: url(${heroBgDark.src})`}></div>
    <div class="absolute inset-0 bg-no-repeat bg-cover bg-center transition-opacity duration-700 opacity-0 global-light-bg" style={`background-image: url(${heroBgLight.src})`}></div>
  </div>
  <div class="glow-violet top-[10%] left-[20%] animate-float opacity-30"></div>
  <div class="glow-rose bottom-[20%] right-[10%] animate-float delay-300 opacity-30"></div>

  <!-- Content -->
  <div class="relative z-10 max-w-[var(--container-max)] mx-auto px-6 py-24 text-center">
    <!-- Label -->
    <div class="animate-fade-up">
      <span class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full bg-violet/10 border border-violet/20 text-violet text-sm font-medium mb-8">
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M13 10V3L4 14h7v7l9-11h-7z"/></svg>
        {label}
      </span>
    </div>

    <!-- Headline -->
    <h1 class="text-4xl sm:text-5xl lg:text-6xl font-bold font-heading max-w-4xl mx-auto leading-tight animate-fade-up delay-100">
      <Fragment set:html={title} />
    </h1>

    <!-- Subtitle -->
    {subtitle && (
      <p class="text-lg sm:text-xl text-text-secondary max-w-2xl mx-auto mt-6 animate-fade-up delay-200">
        {subtitle}
      </p>
    )}

    <!-- CTAs -->
    <div class="flex flex-col sm:flex-row items-center justify-center gap-4 mt-10 animate-fade-up delay-300">
      <a
        href={primaryCTA.href}
        class="inline-flex items-center gap-2 px-6 py-3 rounded-xl bg-gradient-to-r from-violet to-rose text-white font-medium hover:opacity-90 transition-opacity text-base"
      >
        {primaryCTA.label}
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M7 17L17 7M17 7H7M17 7v10"/></svg>
      </a>
      <a
        href={secondaryCTA.href}
        class="inline-flex items-center gap-2 px-6 py-3 rounded-xl border border-border text-text-secondary font-medium hover:border-violet hover:text-violet transition-colors text-base"
      >
        {secondaryCTA.label}
      </a>
    </div>

    <!-- Stats -->
    {stats && (
      <div class="grid grid-cols-2 sm:grid-cols-3 gap-8 mt-16 max-w-2xl mx-auto animate-fade-up delay-400">
        {stats.map((stat) => (
          <div class="text-center">
            <div class="text-3xl sm:text-4xl font-bold font-heading text-gradient" data-counter={stat.value}>
              {stat.value}
            </div>
            <div class="text-sm text-text-secondary mt-1">{stat.label}</div>
          </div>
        ))}
      </div>
    )}
  </div>
</section>

<style is:global>
  body.light .global-dark-bg {
    opacity: 0 !important;
  }
  body.light .global-light-bg {
    opacity: 0.6 !important;
  }
</style>
