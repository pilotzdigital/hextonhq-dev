---
interface Props {
  name: string;
  price: string;
  period?: string;
  description: string;
  features: string[];
  cta?: { label: string; href: string };
  popular?: boolean;
}

const {
  name,
  price,
  period = '/mo',
  description,
  features,
  cta = { label: 'Get Started', href: '/contact' },
  popular = false,
} = Astro.props;
---

<div class:list={[
  'relative glass rounded-2xl p-8 flex flex-col',
  popular && 'border-violet/50 ring-1 ring-violet/30',
  !popular && 'border-border',
]}>
  {popular && (
    <div class="absolute -top-3 left-1/2 -translate-x-1/2">
      <span class="px-3 py-1 rounded-full bg-gradient-to-r from-violet to-rose text-white text-xs font-bold uppercase tracking-wider">
        Most Popular
      </span>
    </div>
  )}

  <div class="mb-6">
    <h3 class="text-lg font-heading font-bold mb-2">{name}</h3>
    <p class="text-text-secondary text-sm">{description}</p>
  </div>

  <div class="flex items-baseline gap-1 mb-6">
    <span class:list={['text-4xl font-heading font-bold', popular && 'text-gradient']}>{price}</span>
    {period && <span class="text-text-secondary text-sm">{period}</span>}
  </div>

  <ul class="space-y-3 mb-8 flex-1">
    {features.map((feature) => (
      <li class="flex items-start gap-3 text-sm">
        <svg class="w-5 h-5 text-success shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M5 13l4 4L19 7"/></svg>
        <span class="text-text-secondary">{feature}</span>
      </li>
    ))}
  </ul>

  <a
    href={cta.href}
    class:list={[
      'block text-center py-3 rounded-xl font-medium transition-all',
      popular
        ? 'bg-gradient-to-r from-violet to-rose text-white hover:opacity-90'
        : 'border border-border text-text hover:border-violet hover:text-violet',
    ]}
  >
    {cta.label}
  </a>
</div>
