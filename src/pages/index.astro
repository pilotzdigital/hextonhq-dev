---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/ui/Hero.astro';
import SectionHeading from '../components/ui/SectionHeading.astro';
import ServiceCard from '../components/ui/ServiceCard.astro';
import GlassCard from '../components/ui/GlassCard.astro';
import CTASection from '../components/ui/CTASection.astro';
import CapabilitiesCarousel from '../components/ui/CapabilitiesCarousel.astro';
import InteractiveShowcase from '../components/ui/InteractiveShowcase.astro';
import TechStackMatrix from '../components/ui/TechStackMatrix.astro';
import FAQAccordion from '../components/ui/FAQAccordion.astro';

// Section 2: Interactive Showcase - Social Proof Cards
const showcaseCards = [
  {
    metric: "4 Hours → 2 Seconds",
    description: "Automated CRM Lead Enrichment via n8n."
  },
  {
    metric: "+125% Conversion",
    description: "Full-Funnel Growth Hacking & CRO."
  },
  {
    metric: "Zero Lock-in",
    description: "Open-Source Marketing Stack Deployment."
  }
];

// Section 4: Capabilities cards data
const capabilitiesCards = [
  {
    hook: "You are paying brilliant people to do robot work. Let's fix that.",
    title: "AI & Workflow Automation",
    description: "We deploy autonomous agent systems that handle your lead generation, enrichment, and outreach behind the scenes. Your team does the closing; the system does the rest."
  },
  {
    hook: "Great products don't sell themselves. Systems do.",
    title: "Fractional CMO & Marketing Ops",
    description: "We don't just hand you a strategy deck. We step in to audit your stack, install the growth engines, and run your marketing operations like a high-precision machine."
  },
  {
    hook: "When AI answers the user's question, where does your website go?",
    title: "Generative Engine Optimization (GEO)",
    description: "Traditional search is fading. We optimize your brand to be cited by the AI engines—like Perplexity and Google's AI Overviews—that your future customers are already using."
  },
  {
    hook: "Buying the software is the easy part. Getting your team to use it is where we come in.",
    title: "AI Enablement & Consulting",
    description: "We run hands-on, intensive sprints to turn your staff from hesitant users into AI-native builders who actually own and understand their new workflows."
  },
  {
    hook: "How much of your week is spent moving information from one tab to another?",
    title: "Internal Process Automation",
    description: "We eliminate the operational bottlenecks in HR, finance, and internal ops by installing invisible automations that run exactly the way your business does."
  },
  {
    hook: "Stop paying monthly rent for software you don't even own.",
    title: "Custom CRM & Client Portals",
    description: "We build proprietary infrastructure—tailored to your exact workflow—on enterprise-grade open-source tools. You own the code, the data, and the servers. Zero seat licenses."
  },
  {
    hook: "You have dashboards. You just don't have answers.",
    title: "Data Infrastructure & Analytics",
    description: "We deploy secure, self-hosted data stacks that connect the dots between your marketing spend and your actual revenue, giving you total privacy and absolute clarity."
  },
  {
    hook: "Your five-person team can out-execute a fifty-person agency.",
    title: "Specialized Team Upskilling",
    description: "We deliver deep, technical upskilling for your ambitious marketing and sales units. We teach them the exact frameworks to deploy, prompt, and manage AI systems that scale your output tenfold."
  }
];

// Section 5: Tech Stack Matrix
const techCategories = [
  {
    category: "Automation",
    tools: ["n8n", "Make", "Zapier"]
  },
  {
    category: "AI/LLMs",
    tools: ["OpenAI", "Anthropic", "LangChain", "Vercel AI SDK"]
  },
  {
    category: "Data/Hosting",
    tools: ["Supabase", "Dokploy", "Postgres", "Matomo"]
  },
  {
    category: "Frontend",
    tools: ["Astro", "Next.js", "Payload CMS"]
  }
];

// Section 8: FAQ Data
const faqData = [
  {
    question: "Do you charge an upfront fee or a monthly retainer?",
    answer: "We offer both. For custom AI architecture (like a conversational agent or proprietary CRM), we charge a flat build fee. For Fractional CMO and continuous Growth Hacking, we operate on a fixed monthly retainer."
  },
  {
    question: "What do you mean by \"Open-Source Infrastructure\"?",
    answer: "Most agencies build your systems on expensive platforms like HubSpot or Salesforce, meaning you are locked in forever. We build on enterprise-grade open-source tools hosted on your own servers. You own the code and the data."
  },
  {
    question: "How does the Team Enablement work?",
    answer: "It's not a generic PowerPoint. We come in (remotely or in-person) and run agile sprints, training your marketing and sales staff exactly how to use the custom automation workflows we just built for you."
  }
];
---

<BaseLayout
  title="The AI Adoption Company | HextonHQ"
  description="Extraordinary things happen when extraordinary technology reaches ordinary people. HextonHQ gives organizations and individuals the architecture to build an AI-native future."
>
  <!-- Section 1: Hero -->
  <Hero
    label="The AI Adoption Company"
    title='Extraordinary things happen when <span class="text-gradient">extraordinary technology</span> reaches ordinary people.'
    subtitle="The world's most powerful tools shouldn't be locked behind Fortune 500 budgets. We build open-source AI architecture that scales your growth, automates your operations, and trains your team to own it."
    primaryCTA={{ label: 'Build Your Architecture', href: '/contact' }}
    secondaryCTA={{ label: 'See Our Beliefs', href: '#brand-story' }}
  />

  <!-- Section 2: THE INTERACTIVE SHOWCASE (Social Proof) -->
  <InteractiveShowcase 
    cards={showcaseCards}
    label="Our Output"
    headline="Not theory. <span class='text-gradient'>Architecture.</span>"
  />

  <!-- Section 3: THE BRAND STORY — "This Has Happened Before" -->
  <section class="py-24 relative" id="brand-story">
    <div class="max-w-[var(--container-max)] mx-auto px-6">
      <SectionHeading
        label="Why We Exist"
        title="This has <span class='text-gradient'>happened before.</span>"
      />
      
      <div class="max-w-3xl mx-auto mt-12 space-y-6 text-lg text-text-secondary leading-relaxed">
        <p>
          When electricity arrived, factories that adopted it didn't just get brighter rooms — they redesigned everything. Assembly lines. Shifts. Entire industries, born overnight. The ones that waited? They didn't get a second chance.
        </p>
        <p>
          AI is that moment.
        </p>
        <p>
          Not the chatbot on a website. Not the auto-generated email. The real thing — systems that think, learn, and execute at a speed no human team can match alone.
        </p>
        <p>
          But here's what nobody talks about: electricity didn't just change factories. It changed <em>people</em>. Entirely new professions. New businesses. New ways of living. The ones who learned to work <em>with</em> it built empires. The ones who feared it got left behind.
        </p>
        <p class="font-medium text-text">
          We started HextonHQ because we believe the size of your team should never limit the size of your ambition. And right now, AI is the greatest equalizer the world has ever seen — if you know how to use it.
        </p>
      </div>
    </div>
  </section>

  <!-- Section 4: OUR CAPABILITIES (The Offerings) - Interactive Glassmorphic Carousel -->
  <CapabilitiesCarousel 
    cards={capabilitiesCards}
    label="Our Architecture"
    headline="We don't sell advice. We <span class='text-gradient'>install systems.</span>"
  />

  <!-- Section 5: THE INFRASTRUCTURE (Tech Stack Matrix) -->
  <TechStackMatrix 
    categories={techCategories}
    headline="Open by default. <span class='text-gradient'>Scalable by design.</span>"
  />

  <!-- Section 6: IDENTITY - Adopt. Scale. Prepare. -->
  <section class="py-24 relative">
    <div class="max-w-[var(--container-max)] mx-auto px-6">
      <SectionHeading
        label="Our Approach"
        title="<span class='text-gradient'>Adopt.</span> Scale. Prepare."
      />

      <div class="grid grid-cols-1 md:grid-cols-3 gap-8 mt-16">
        <ServiceCard
          icon="bolt"
          title="Adopt."
          description="We don't sell AI. We install it into your workflows, your operations, your culture. Not advice. Not decks. Working systems you own."
        />
        <ServiceCard
          icon="chart"
          title="Scale."
          description="From go-to-market strategy to marketing architecture — we build the engine that grows with you. Open-source, no lock-in, designed for compound returns."
        />
        <ServiceCard
          icon="shield"
          title="Prepare."
          description="The AI economy rewards builders, not bystanders. We train individuals and teams to operate in an AI-native world — before the market decides for them."
        />
      </div>
    </div>
  </section>

  <!-- Section 7: VALUES -->
  <section class="py-24 relative bg-violet/5">
    <div class="max-w-[var(--container-max)] mx-auto px-6">
      <SectionHeading
        label="What We Stand For"
        title="Five things we'll <span class='text-gradient'>never compromise</span> on."
      />

      <div class="mt-16 max-w-4xl mx-auto space-y-6">
        {[
          { title: "Build, don't advise.", desc: "Strategy without implementation is a PowerPoint. We ship systems that work." },
          { title: "Open by default.", desc: "Your code, your data, your infrastructure. No vendor lock-in. No hidden dependencies." },
          { title: "Earn trust, not dependence.", desc: "Our job is done when you don't need us anymore." },
          { title: "Stay a student.", desc: "The AI landscape changes weekly. We stay curious and share what we learn." },
          { title: "Measure in impact, not hours.", desc: "We don't bill for effort. We charge for outcomes." }
        ].map((value, index) => (
          <GlassCard class="flex flex-col sm:flex-row gap-6 items-start sm:items-center p-6 sm:p-8" hover={false}>
            <div class="flex-shrink-0 w-12 h-12 rounded-full bg-gradient-to-br from-violet/20 to-rose/20 flex items-center justify-center text-xl font-bold text-violet border border-violet/20">
              0{index + 1}
            </div>
            <div>
              <h3 class="text-xl font-bold font-heading text-text mb-2">{value.title}</h3>
              <p class="text-text-secondary">{value.desc}</p>
            </div>
          </GlassCard>
        ))}
      </div>
    </div>
  </section>

  <!-- Section 8: COMMON QUESTIONS (FAQ) -->
  <FAQAccordion 
    faqs={faqData}
    label="Common Questions"
    headline="The Clarity You <span class='text-gradient'>Need.</span>"
  />

  <!-- Section 9: FOUNDER'S NOTE -->
  <section class="py-24 relative">
    <div class="absolute inset-0 bg-gradient-to-b from-transparent via-violet/5 to-transparent"></div>
    <div class="relative z-10 max-w-4xl mx-auto px-6">
      <SectionHeading
        label="A Note from the Founder"
        title="&quot;I built HextonHQ for the <span class='text-gradient'>builder in between.</span>&quot;"
      />

      <GlassCard class="p-8 sm:p-12 mt-16 relative overflow-hidden" hover={false}>
        <div class="absolute top-0 right-0 w-64 h-64 bg-violet/10 rounded-full blur-3xl -translate-y-1/2 translate-x-1/2"></div>
        
        <div class="relative z-10 space-y-6 text-text-secondary leading-relaxed text-lg">
          <p>Giant companies were using AI to move at light speed — automating workflows, personalizing at scale, making decisions faster than any human team could. And small businesses? Founders? Growing teams? They were stuck choosing between tools they couldn't afford and advice they couldn't act on.</p>
          
          <p>I built HextonHQ for the builder in between. The person with the ambition of a giant and the budget of a startup. The team that knows AI matters but doesn't have a dedicated AI department.</p>

          <p class="font-medium text-text border-l-4 border-violet pl-6 py-2">We exist to close that gap. To bring the most powerful tools in the world to the people who will do the most extraordinary things with them.</p>

          <div class="pt-8 mt-8 border-t border-border/50 flex items-center gap-4">
            <div class="w-16 h-16 rounded-full bg-gradient-to-r from-violet to-rose flex items-center justify-center text-white font-bold text-2xl shadow-lg">
              VR
            </div>
            <div>
              <div class="font-bold font-heading text-text text-xl">Vishnu Raam</div>
              <div class="text-violet font-medium">Founder</div>
            </div>
          </div>
        </div>
      </GlassCard>
    </div>
  </section>

  <!-- Section 10: CLOSING CTA -->
  <CTASection
    title="The divide is real. <span class='text-gradient'>Which side are you building on?</span>"
    subtitle="Whether you're an organization adopting AI or an individual preparing for what's next — the conversation starts here."
    cta={{ label: 'Start the Conversation', href: '/contact' }}
  />
</BaseLayout>
