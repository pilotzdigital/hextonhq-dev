---
const navLinks = [
  { label: 'Services', href: '/services' },
  { label: 'About', href: '/about' },
  { label: 'Pricing', href: '/pricing' },
  { label: 'Blog', href: '/blog' },
  { label: 'Contact', href: '/contact' },
];

const currentPath = Astro.url.pathname;
---

<header class="fixed top-0 left-0 right-0 z-50 glass" id="site-header">
  <nav class="max-w-[var(--container-wide)] mx-auto px-6 h-16 flex items-center justify-between">
    <!-- Logo -->
    <a href="/" class="flex items-center gap-2 font-heading font-bold text-xl">
      <span class="text-text">Hexton</span><span class="text-gradient">HQ</span>
    </a>

    <!-- Desktop Nav -->
    <ul class="hidden md:flex items-center gap-8">
      {navLinks.map((link) => (
        <li>
          <a
            href={link.href}
            class:list={[
              'text-sm font-medium transition-colors hover:text-violet',
              currentPath.startsWith(link.href) ? 'text-violet' : 'text-text-secondary',
            ]}
          >
            {link.label}
          </a>
        </li>
      ))}
    </ul>

    <!-- Right side -->
    <div class="flex items-center gap-4">
      <!-- Theme Toggle -->
      <button
        id="theme-toggle"
        class="p-2 rounded-lg hover:bg-surface-elevated transition-colors"
        aria-label="Toggle dark/light mode"
      >
        <svg class="w-5 h-5 hidden dark-icon" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z" />
        </svg>
        <svg class="w-5 h-5 hidden light-icon" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <circle cx="12" cy="12" r="5" /><line x1="12" y1="1" x2="12" y2="3" /><line x1="12" y1="21" x2="12" y2="23" /><line x1="4.22" y1="4.22" x2="5.64" y2="5.64" /><line x1="18.36" y1="18.36" x2="19.78" y2="19.78" /><line x1="1" y1="12" x2="3" y2="12" /><line x1="21" y1="12" x2="23" y2="12" /><line x1="4.22" y1="19.78" x2="5.64" y2="18.36" /><line x1="18.36" y1="5.64" x2="19.78" y2="4.22" />
        </svg>
      </button>

      <!-- CTA -->
      <a
        href="/contact"
        class="hidden sm:inline-flex items-center gap-2 px-4 py-2 rounded-lg bg-gradient-to-r from-violet to-rose text-white text-sm font-medium hover:opacity-90 transition-opacity"
      >
        Get Started
      </a>

      <!-- Mobile menu button -->
      <button
        id="mobile-menu-btn"
        class="md:hidden p-2 rounded-lg hover:bg-surface-elevated transition-colors"
        aria-label="Open menu"
      >
        <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path d="M4 6h16M4 12h16M4 18h16" />
        </svg>
      </button>
    </div>
  </nav>

  <!-- Mobile Nav -->
  <div id="mobile-menu" class="hidden md:hidden glass border-t border-border">
    <ul class="px-6 py-4 space-y-3">
      {navLinks.map((link) => (
        <li>
          <a
            href={link.href}
            class:list={[
              'block py-2 text-sm font-medium transition-colors hover:text-violet',
              currentPath.startsWith(link.href) ? 'text-violet' : 'text-text-secondary',
            ]}
          >
            {link.label}
          </a>
        </li>
      ))}
      <li class="pt-2">
        <a
          href="/contact"
          class="block text-center px-4 py-2 rounded-lg bg-gradient-to-r from-violet to-rose text-white text-sm font-medium"
        >
          Get Started
        </a>
      </li>
    </ul>
  </div>
</header>

<script>
  // Mobile menu toggle
  const menuBtn = document.getElementById('mobile-menu-btn')!;
  const menu = document.getElementById('mobile-menu')!;
  menuBtn.addEventListener('click', () => {
    menu.classList.toggle('hidden');
  });

  // Theme toggle
  const themeBtn = document.getElementById('theme-toggle')!;
  const darkIcon = themeBtn.querySelector('.dark-icon') as HTMLElement;
  const lightIcon = themeBtn.querySelector('.light-icon') as HTMLElement;

  function setTheme(light: boolean) {
    document.body.classList.toggle('light', light);
    darkIcon.classList.toggle('hidden', light);
    lightIcon.classList.toggle('hidden', !light);
    localStorage.setItem('theme', light ? 'light' : 'dark');
  }

  const stored = localStorage.getItem('theme');
  const prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
  setTheme(stored === 'light' || (!stored && !prefersDark));

  // Default: dark mode (HextonHQ brand is dark-first)
  if (!stored) setTheme(false);

  themeBtn.addEventListener('click', () => {
    setTheme(!document.body.classList.contains('light'));
  });
</script>
