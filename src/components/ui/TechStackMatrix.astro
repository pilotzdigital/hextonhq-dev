---
/**
 * Section 5: THE INFRASTRUCTURE - Tech Stack Marquee
 * Dual-row infinite scrolling marquee with 100+ tools
 */
import SectionHeading from './SectionHeading.astro';

interface Props {
  headline?: string;
  subheadline?: string;
}

const { 
  headline = "Open by default. <span class='text-gradient'>Scalable by design.</span>",
  subheadline = "We don't lock you into expensive vendor ecosystems. We build your systems using the world's most powerful open-source and enterprise frameworks—hosted entirely on your own servers."
} = Astro.props;

// Row 1: AI, Automation & Logic (Moving Left)
const row1Tools = [
  "OpenAI", "Anthropic", "Claude", "n8n", "LangChain", "Make", "Flowise", 
  "Google Gemini", "Meta Llama 3", "Mistral AI", "Ollama", "vLLM", "LM Studio",
  "Groq", "CrewAI", "AutoGen", "LlamaIndex", "Semantic Kernel", "Dify",
  "AnythingLLM", "LibreChat", "Activepieces", "Pipedream", "Windmill", "Kestra",
  "Prefect", "Node-RED", "Huginn", "Pinecone", "Weaviate", "Milvus", "Qdrant",
  "ChromaDB", "Typesense", "Meilisearch", "Promptflow", "LangGraph", "MemGPT",
  "LocalAI", "PrivateGPT", "Cohere", "Hugging Face", "Perplexity", "ElevenLabs"
];

// Row 2: Infrastructure, Data & Frontend (Moving Right)
const row2Tools = [
  "Dokploy", "Coolify", "CapRover", "Astro", "Next.js", "Supabase", "Matomo",
  "Payload CMS", "Docker", "Kubernetes", "Portainer", "Traefik", "Cloudflare",
  "Vercel", "Netlify", "Railway", "Render", "Fly.io", "React", "Vue.js",
  "SvelteKit", "Nuxt.js", "HTMX", "Tailwind CSS", "Framer Motion", "Node.js",
  "Python", "Go", "FastAPI", "Express", "Postgres", "MySQL", "Redis",
  "Appwrite", "PocketBase", "NocoDB", "Baserow", "Directus", "Strapi",
  "Plausible", "PostHog", "Umami", "Grafana", "Prometheus", "Sentry", "Prisma"
];
---

<section class="tech-marquee-section py-24 relative overflow-hidden bg-surface/30" id="infrastructure" data-testid="tech-stack-section">
  <!-- Background effects -->
  <div class="absolute inset-0 pointer-events-none">
    <div class="absolute w-[500px] h-[500px] rounded-full bg-gradient-to-br from-violet/10 to-transparent blur-[120px] top-1/2 -left-32 -translate-y-1/2"></div>
    <div class="absolute w-[400px] h-[400px] rounded-full bg-gradient-to-tl from-rose/10 to-transparent blur-[100px] top-1/2 -right-20 -translate-y-1/2"></div>
  </div>

  <div class="max-w-5xl mx-auto px-6 relative z-10 mb-16">
    <div class="text-center">
      <span class="text-sm font-mono font-medium uppercase tracking-wider text-gold">The Infrastructure</span>
      <h2 class="text-3xl sm:text-4xl md:text-5xl font-bold font-heading mt-3" set:html={headline} />
      <p class="text-text-secondary text-lg mt-4 max-w-3xl mx-auto leading-relaxed">
        {subheadline}
      </p>
    </div>
  </div>

  <!-- Marquee Container -->
  <div class="marquee-container relative" data-testid="tech-marquee">
    <!-- Gradient fade edges -->
    <div class="absolute left-0 top-0 bottom-0 w-32 bg-gradient-to-r from-bg to-transparent z-10 pointer-events-none"></div>
    <div class="absolute right-0 top-0 bottom-0 w-32 bg-gradient-to-l from-bg to-transparent z-10 pointer-events-none"></div>

    <!-- Row 1: AI & Automation (Moving Left) -->
    <div class="marquee-row mb-4 overflow-hidden">
      <div class="marquee-track marquee-left flex gap-4">
        {[...row1Tools, ...row1Tools].map((tool) => (
          <div class="tool-chip shrink-0 px-5 py-3 rounded-full glass border border-white/5 hover:border-violet/40 transition-all duration-300 hover:scale-105 hover:bg-violet/10 cursor-default group">
            <div class="flex items-center gap-2">
              <div class="w-2 h-2 rounded-full bg-violet/50 group-hover:bg-violet group-hover:shadow-[0_0_8px_rgba(168,85,247,0.8)] transition-all"></div>
              <span class="text-text-secondary group-hover:text-white transition-colors font-medium text-sm whitespace-nowrap">{tool}</span>
            </div>
          </div>
        ))}
      </div>
    </div>

    <!-- Row 2: Infrastructure & Frontend (Moving Right) -->
    <div class="marquee-row overflow-hidden">
      <div class="marquee-track marquee-right flex gap-4">
        {[...row2Tools, ...row2Tools].map((tool) => (
          <div class="tool-chip shrink-0 px-5 py-3 rounded-full glass border border-white/5 hover:border-rose/40 transition-all duration-300 hover:scale-105 hover:bg-rose/10 cursor-default group">
            <div class="flex items-center gap-2">
              <div class="w-2 h-2 rounded-full bg-rose/50 group-hover:bg-rose group-hover:shadow-[0_0_8px_rgba(251,113,133,0.8)] transition-all"></div>
              <span class="text-text-secondary group-hover:text-white transition-colors font-medium text-sm whitespace-nowrap">{tool}</span>
            </div>
          </div>
        ))}
      </div>
    </div>
  </div>

  <!-- Bottom tagline -->
  <div class="max-w-5xl mx-auto px-6 relative z-10 mt-16">
    <p class="text-center text-text-secondary text-lg">
      You own the code. You own the data. <span class="text-gold font-medium">No vendor lock-in.</span>
    </p>
  </div>
</section>

<style>
  .marquee-track {
    animation-timing-function: linear;
    animation-iteration-count: infinite;
  }

  .marquee-left {
    animation: marqueeLeft 60s linear infinite;
  }

  .marquee-right {
    animation: marqueeRight 60s linear infinite;
  }

  @keyframes marqueeLeft {
    0% { transform: translateX(0); }
    100% { transform: translateX(-50%); }
  }

  @keyframes marqueeRight {
    0% { transform: translateX(-50%); }
    100% { transform: translateX(0); }
  }

  /* Pause on hover */
  .marquee-row:hover .marquee-track {
    animation-play-state: paused;
  }

  /* Tool chip hover glow */
  .tool-chip:hover {
    box-shadow: 0 0 20px rgba(168, 85, 247, 0.15);
  }
</style>

<script>
  // Optional: Pause marquee when not in viewport for performance
  function initMarquee() {
    const section = document.querySelector('.tech-marquee-section');
    const tracks = document.querySelectorAll('.marquee-track');
    
    if (!section || !tracks.length) return;

    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        tracks.forEach(track => {
          if (entry.isIntersecting) {
            (track as HTMLElement).style.animationPlayState = 'running';
          } else {
            (track as HTMLElement).style.animationPlayState = 'paused';
          }
        });
      });
    }, { threshold: 0.1 });

    observer.observe(section);
  }

  document.addEventListener('astro:page-load', initMarquee);
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initMarquee);
  } else {
    initMarquee();
  }
</script>
