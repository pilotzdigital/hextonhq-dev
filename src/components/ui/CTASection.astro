---
interface Props {
  title: string;
  subtitle?: string;
  cta?: { label: string; href: string };
}

const {
  title,
  subtitle,
  cta = { label: 'Get Started', href: '/contact' },
} = Astro.props;
---

<section class="relative py-24 overflow-hidden">
  <div class="absolute inset-0 bg-gradient-to-r from-violet/10 to-rose/10"></div>
  <div class="glow-violet top-[-200px] right-[-100px]"></div>

  <div class="relative z-10 max-w-3xl mx-auto px-6 text-center">
    <h2 class="text-3xl sm:text-4xl font-bold font-heading" set:html={title} />
    {subtitle && <p class="text-text-secondary text-lg mt-4">{subtitle}</p>}
    <a
      href={cta.href}
      class="inline-flex items-center gap-2 px-8 py-4 rounded-xl bg-gradient-to-r from-violet to-rose text-white font-medium hover:opacity-90 transition-opacity text-base mt-8"
    >
      {cta.label}
      <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M7 17L17 7M17 7H7M17 7v10"/></svg>
    </a>
  </div>
</section>
