---
interface Props {
  icon: string;
  title: string;
  description: string;
  href?: string;
}

const { icon, title, description, href } = Astro.props;
const Tag = href ? 'a' : 'div';

// Icon SVG mapping
const iconSvgs: Record<string, string> = {
  bolt: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="w-6 h-6"><path stroke-linecap="round" stroke-linejoin="round" d="M3.75 13.5l10.5-11.25L12 10.5h8.25L9.75 21.75 12 13.5H3.75z"/></svg>`,
  chart: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="w-6 h-6"><path stroke-linecap="round" stroke-linejoin="round" d="M2.25 18L9 11.25l4.306 4.307a11.95 11.95 0 015.814-5.519l2.74-1.22m0 0l-5.94-2.28m5.94 2.28l-2.28 5.941"/></svg>`,
  shield: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="w-6 h-6"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75m-3-7.036A11.959 11.959 0 013.598 6 11.99 11.99 0 003 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285z"/></svg>`,
};

const iconContent = iconSvgs[icon] || icon;
const isEmoji = !iconSvgs[icon];
---

<Tag
  href={href}
  class="glass rounded-2xl p-6 card-glow gradient-border group block magic-tilt"
>
  <div class="w-12 h-12 rounded-xl bg-gradient-to-br from-violet/20 to-rose/10 flex items-center justify-center mb-4 group-hover:bg-violet/20 transition-colors text-violet border border-violet/20">
    {isEmoji ? (
      <span class="text-2xl">{icon}</span>
    ) : (
      <Fragment set:html={iconContent} />
    )}
  </div>
  <h3 class="text-lg font-bold font-heading mb-2 group-hover:text-violet transition-colors">{title}</h3>
  <p class="text-text-secondary text-sm leading-relaxed">{description}</p>
  {href && (
    <span class="inline-flex items-center gap-1 text-violet text-sm font-medium mt-4 opacity-0 group-hover:opacity-100 transition-opacity">
      Learn more
      <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M7 17L17 7M17 7H7M17 7v10"/></svg>
    </span>
  )}
</Tag>
