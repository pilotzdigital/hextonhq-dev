---
/**
 * Section 2: THE INTERACTIVE SHOWCASE
 * 6 glassmorphic case study cards with metrics
 */
import SectionHeading from './SectionHeading.astro';

interface ShowcaseCard {
  metric: string;
  title: string;
  description: string;
}

interface Props {
  cards: ShowcaseCard[];
  label?: string;
  headline?: string;
  subheadline?: string;
}

const { 
  cards, 
  label = "Our Output", 
  headline = "Not theory. <span class='text-gradient'>Architecture.</span>",
  subheadline = "A look inside the systems we build and the bottlenecks we break."
} = Astro.props;
---

<section class="showcase-section py-24 relative overflow-hidden" id="showcase" data-testid="showcase-section">
  <!-- Background glow effects -->
  <div class="absolute inset-0 pointer-events-none">
    <div class="absolute w-[600px] h-[600px] rounded-full bg-gradient-to-br from-violet/15 to-transparent blur-[120px] -top-32 left-1/4"></div>
    <div class="absolute w-[500px] h-[500px] rounded-full bg-gradient-to-tl from-rose/10 to-transparent blur-[100px] -bottom-20 right-1/4"></div>
  </div>

  <div class="max-w-7xl mx-auto px-6 relative z-10">
    <SectionHeading 
      label={label}
      title={headline}
      subtitle={subheadline}
      align="center"
    />

    <!-- Showcase Cards Grid - 2x3 layout -->
    <div class="showcase-cards grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 mt-16" data-testid="showcase-cards">
      {cards.map((card, index) => (
        <div 
          class="showcase-card group relative"
          data-testid={`showcase-card-${index}`}
          style={`animation-delay: ${index * 100}ms`}
        >
          <div class="glass rounded-3xl p-8 h-full relative overflow-hidden card-glow gradient-border transition-all duration-500 hover:scale-[1.02]">
            <!-- Animated gradient background on hover -->
            <div class="absolute inset-0 bg-gradient-to-br from-violet/10 via-transparent to-rose/10 opacity-0 group-hover:opacity-100 transition-opacity duration-700"></div>
            
            <!-- Top gradient line -->
            <div class="absolute top-0 left-1/2 -translate-x-1/2 w-1/2 h-px bg-gradient-to-r from-transparent via-violet/50 to-transparent"></div>
            
            <div class="relative z-10">
              <!-- Metric - Large gradient number/text -->
              <div class="metric-value text-3xl md:text-4xl font-bold font-heading mb-3 bg-gradient-to-r from-violet to-rose bg-clip-text text-transparent">
                {card.metric}
              </div>
              
              <!-- Title -->
              <h3 class="text-lg font-bold font-heading text-white mb-3">
                {card.title}
              </h3>
              
              <!-- Description -->
              <p class="text-text-secondary leading-relaxed text-sm">
                {card.description}
              </p>
            </div>

            <!-- Decorative corner accent -->
            <div class="absolute bottom-0 right-0 w-20 h-20 bg-gradient-to-tl from-violet/5 to-transparent rounded-tl-full"></div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .showcase-card {
    animation: revealCard 0.8s ease-out forwards;
  }

  @keyframes revealCard {
    from {
      opacity: 0;
      transform: translateY(30px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  /* Metric animation effect */
  .metric-value {
    background-size: 200% 200%;
    animation: gradientShift 4s ease infinite;
  }

  @keyframes gradientShift {
    0%, 100% { background-position: 0% 50%; }
    50% { background-position: 100% 50%; }
  }
</style>

<script>
  function initShowcase() {
    const cards = document.querySelectorAll('.showcase-card');
    
    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          entry.target.style.animationPlayState = 'running';
        }
      });
    }, { threshold: 0.2 });

    cards.forEach(card => {
      (card as HTMLElement).style.animationPlayState = 'paused';
      observer.observe(card);
    });
  }

  document.addEventListener('astro:page-load', initShowcase);
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initShowcase);
  } else {
    initShowcase();
  }
</script>
