  private async typeResponse(text: string) {
    this.responseText.textContent = '';
    this.responseText.classList.add('typing-cursor');
    
    // Fast typing for better UX
    const typingSpeed = 2;
    
    for (let i = 0; i < text.length; i++) {
      this.responseText.textContent += text[i];
      // Update scroll position every 100 chars
      if (i % 100 === 0) {
        this.canvasContent.scrollTop = this.canvasContent.scrollHeight;
      }
      await new Promise(resolve => setTimeout(resolve, typingSpeed));
    }
    
    this.responseText.classList.remove('typing-cursor');
    // Ensure final scroll to bottom
    this.canvasContent.scrollTop = this.canvasContent.scrollHeight;
  }

  private getDeviceType(): string {
    const ua = navigator.userAgent;
    if (/tablet|ipad|playbook|silk/i.test(ua)) return 'tablet';
    if (/mobile|iphone|ipod|android|blackberry|opera mini|iemobile/i.test(ua)) return 'mobile';
    return 'desktop';
  }

  private resetTerminal() {
    // Reset form
    this.input.value = '';
    this.input.disabled = false;
    this.submitBtn.disabled = false;

    // Hide AI response
    this.aiResponseArea.classList.add('hidden');
    this.aiLoading.classList.add('hidden');
    this.aiResponseContent.classList.add('hidden');
    this.responseCta.classList.add('hidden');
    this.responseText.textContent = '';

    // Show case study content
    this.showContent(this.currentIndex);
  }
