---
import SectionHeading from './SectionHeading.astro';

interface CarouselCard {
  hook: string;
  title: string;
  description: string;
  icon?: string;
}

interface Props {
  cards: CarouselCard[];
  label?: string;
  headline?: string;
}

const { cards, label = "Our Architecture", headline = "We don't sell advice. We install systems." } = Astro.props;

// Icon mapping for cards
const cardIcons = [
  `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="w-8 h-8"><path d="M9.75 3.104v5.714a2.25 2.25 0 01-.659 1.591L5 14.5M9.75 3.104c-.251.023-.501.05-.75.082m.75-.082a24.301 24.301 0 014.5 0m0 0v5.714c0 .597.237 1.17.659 1.591L19.8 15.3M14.25 3.104c.251.023.501.05.75.082M19.8 15.3l-1.57.393A9.065 9.065 0 0112 15a9.065 9.065 0 00-6.23.693L5 14.5m14.8.8l1.402 5.902A2.25 2.25 0 0119.04 23H4.96a2.25 2.25 0 01-2.162-1.798L4.2 15.3"/></svg>`,
  `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="w-8 h-8"><path d="M3 13.125C3 12.504 3.504 12 4.125 12h2.25c.621 0 1.125.504 1.125 1.125v6.75C7.5 20.496 6.996 21 6.375 21h-2.25A1.125 1.125 0 013 19.875v-6.75zM9.75 8.625c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125v11.25c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 01-1.125-1.125V8.625zM16.5 4.125c0-.621.504-1.125 1.125-1.125h2.25C20.496 3 21 3.504 21 4.125v15.75c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 01-1.125-1.125V4.125z"/></svg>`,
  `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="w-8 h-8"><path d="M12 21a9.004 9.004 0 008.716-6.747M12 21a9.004 9.004 0 01-8.716-6.747M12 21c2.485 0 4.5-4.03 4.5-9S14.485 3 12 3m0 18c-2.485 0-4.5-4.03-4.5-9S9.515 3 12 3m0 0a8.997 8.997 0 017.843 4.582M12 3a8.997 8.997 0 00-7.843 4.582m15.686 0A11.953 11.953 0 0112 10.5c-2.998 0-5.74-1.1-7.843-2.918m15.686 0A8.959 8.959 0 0121 12c0 .778-.099 1.533-.284 2.253m0 0A17.919 17.919 0 0112 16.5c-3.162 0-6.133-.815-8.716-2.247m0 0A9.015 9.015 0 003 12c0-1.605.42-3.113 1.157-4.418"/></svg>`,
  `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="w-8 h-8"><path d="M4.26 10.147a60.436 60.436 0 00-.491 6.347A48.627 48.627 0 0112 20.904a48.627 48.627 0 018.232-4.41 60.46 60.46 0 00-.491-6.347m-15.482 0a50.57 50.57 0 00-2.658-.813A59.905 59.905 0 0112 3.493a59.902 59.902 0 0110.399 5.84c-.896.248-1.783.52-2.658.814m-15.482 0A50.697 50.697 0 0112 13.489a50.702 50.702 0 017.74-3.342M6.75 15a.75.75 0 100-1.5.75.75 0 000 1.5zm0 0v-3.675A55.378 55.378 0 0112 8.443m-7.007 11.55A5.981 5.981 0 006.75 15.75v-1.5"/></svg>`,
  `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="w-8 h-8"><path d="M10.5 6h9.75M10.5 6a1.5 1.5 0 11-3 0m3 0a1.5 1.5 0 10-3 0M3.75 6H7.5m3 12h9.75m-9.75 0a1.5 1.5 0 01-3 0m3 0a1.5 1.5 0 00-3 0m-3.75 0H7.5m9-6h3.75m-3.75 0a1.5 1.5 0 01-3 0m3 0a1.5 1.5 0 00-3 0m-9.75 0h9.75"/></svg>`,
  `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="w-8 h-8"><path d="M20.25 6.375c0 2.278-3.694 4.125-8.25 4.125S3.75 8.653 3.75 6.375m16.5 0c0-2.278-3.694-4.125-8.25-4.125S3.75 4.097 3.75 6.375m16.5 0v11.25c0 2.278-3.694 4.125-8.25 4.125s-8.25-1.847-8.25-4.125V6.375m16.5 0v3.75m-16.5-3.75v3.75m16.5 0v3.75C20.25 16.153 16.556 18 12 18s-8.25-1.847-8.25-4.125v-3.75m16.5 0c0 2.278-3.694 4.125-8.25 4.125s-8.25-1.847-8.25-4.125"/></svg>`,
  `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="w-8 h-8"><path d="M7.5 14.25v2.25m3-4.5v4.5m3-6.75v6.75m3-9v9M6 20.25h12A2.25 2.25 0 0020.25 18V6A2.25 2.25 0 0018 3.75H6A2.25 2.25 0 003.75 6v12A2.25 2.25 0 006 20.25z"/></svg>`,
  `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="w-8 h-8"><path d="M18 18.72a9.094 9.094 0 003.741-.479 3 3 0 00-4.682-2.72m.94 3.198l.001.031c0 .225-.012.447-.037.666A11.944 11.944 0 0112 21c-2.17 0-4.207-.576-5.963-1.584A6.062 6.062 0 016 18.719m12 0a5.971 5.971 0 00-.941-3.197m0 0A5.995 5.995 0 0012 12.75a5.995 5.995 0 00-5.058 2.772m0 0a3 3 0 00-4.681 2.72 8.986 8.986 0 003.74.477m.94-3.197a5.971 5.971 0 00-.94 3.197M15 6.75a3 3 0 11-6 0 3 3 0 016 0zm6 3a2.25 2.25 0 11-4.5 0 2.25 2.25 0 014.5 0zm-13.5 0a2.25 2.25 0 11-4.5 0 2.25 2.25 0 014.5 0z"/></svg>`,
];
---

<section class="capabilities-section py-32 overflow-hidden relative" data-testid="capabilities-carousel" id="capabilities">
  <!-- Parallax Background Elements -->
  <div class="absolute inset-0 pointer-events-none overflow-hidden">
    <div class="parallax-orb orb-1 absolute w-[600px] h-[600px] rounded-full bg-gradient-to-br from-violet/20 to-transparent blur-[120px] -top-48 -left-48"></div>
    <div class="parallax-orb orb-2 absolute w-[500px] h-[500px] rounded-full bg-gradient-to-tl from-rose/15 to-transparent blur-[100px] -bottom-32 -right-32"></div>
    <div class="parallax-orb orb-3 absolute w-[300px] h-[300px] rounded-full bg-gradient-to-br from-violet/10 to-rose/10 blur-[80px] top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2"></div>
  </div>

  <!-- Floating particles -->
  <div class="particles absolute inset-0 pointer-events-none">
    {[...Array(12)].map((_, i) => (
      <div 
        class="particle absolute w-1 h-1 bg-violet/40 rounded-full"
        style={`left: ${10 + (i * 7)}%; top: ${20 + (i % 4) * 20}%; animation-delay: ${i * 0.3}s;`}
      />
    ))}
  </div>

  <div class="max-w-7xl mx-auto px-6 mb-16 relative z-10">
    <SectionHeading 
      label={label}
      title={headline}
      align="center"
    />
  </div>

  <!-- Carousel Wrapper -->
  <div class="carousel-wrapper relative" data-testid="carousel-wrapper">
    <!-- Navigation Arrows -->
    <button 
      class="carousel-nav carousel-prev absolute left-4 md:left-8 top-1/2 -translate-y-1/2 z-30 w-14 h-14 rounded-full glass flex items-center justify-center group transition-all duration-300 hover:scale-110 hover:bg-violet/20 border border-white/10 hover:border-violet/40"
      aria-label="Previous card"
      data-testid="carousel-prev"
    >
      <svg class="w-6 h-6 text-white/70 group-hover:text-white transition-colors" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <path d="M15 19l-7-7 7-7"/>
      </svg>
    </button>
    
    <button 
      class="carousel-nav carousel-next absolute right-4 md:right-8 top-1/2 -translate-y-1/2 z-30 w-14 h-14 rounded-full glass flex items-center justify-center group transition-all duration-300 hover:scale-110 hover:bg-violet/20 border border-white/10 hover:border-violet/40"
      aria-label="Next card"
      data-testid="carousel-next"
    >
      <svg class="w-6 h-6 text-white/70 group-hover:text-white transition-colors" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <path d="M9 5l7 7-7 7"/>
      </svg>
    </button>

    <!-- The 3D Carousel Track -->
    <div class="carousel-3d-container perspective-[2000px] h-[540px] relative mx-auto max-w-full overflow-visible">
      <div class="carousel-track absolute inset-0 flex items-center justify-center" style="transform-style: preserve-3d;">
        {cards.map((card, index) => (
          <div 
            class="carousel-card absolute w-[320px] md:w-[400px] transition-all duration-700 ease-out cursor-pointer"
            data-index={index}
            data-testid={`carousel-card-${index}`}
            style="transform-style: preserve-3d;"
          >
            <div class="card-inner glass rounded-3xl p-8 h-[460px] flex flex-col relative overflow-hidden group border border-white/5 hover:border-violet/30 transition-colors duration-500">
              <!-- Animated Gradient Background -->
              <div class="absolute inset-0 bg-gradient-to-br from-violet/5 via-transparent to-rose/5 opacity-0 group-hover:opacity-100 transition-opacity duration-700"></div>
              
              <!-- Glowing Edge Effect -->
              <div class="absolute inset-0 rounded-3xl opacity-0 group-hover:opacity-100 transition-opacity duration-500" style="background: linear-gradient(135deg, rgba(168,85,247,0.1), transparent, rgba(251,113,133,0.1)); filter: blur(1px);"></div>
              
              <!-- Top Gradient Line -->
              <div class="absolute top-0 left-1/2 -translate-x-1/2 w-1/2 h-px bg-gradient-to-r from-transparent via-violet/50 to-transparent"></div>
              
              <div class="relative z-10 flex flex-col h-full">
                <!-- Icon -->
                <div class="w-14 h-14 rounded-2xl bg-gradient-to-br from-violet/20 to-rose/10 flex items-center justify-center mb-6 text-violet border border-violet/20 group-hover:border-violet/40 group-hover:scale-110 transition-all duration-500" set:html={cardIcons[index % cardIcons.length]} />
                
                <!-- Hook -->
                <p class="text-sm font-medium bg-gradient-to-r from-violet to-rose bg-clip-text text-transparent mb-4 leading-relaxed">
                  "{card.hook}"
                </p>
                
                <!-- Title -->
                <h3 class="text-2xl font-bold text-white mb-4 font-heading group-hover:text-gradient transition-all duration-500">
                  {card.title}
                </h3>
                
                <!-- Description -->
                <p class="text-text-secondary leading-relaxed flex-1">
                  {card.description}
                </p>
                
                <!-- Bottom section -->
                <div class="mt-6 pt-6 border-t border-white/5 flex items-center justify-between">
                  <span class="text-xs uppercase tracking-[0.2em] text-text-secondary/60 font-medium">
                    System 0{index + 1}
                  </span>
                  <div class="w-10 h-10 rounded-full bg-white/5 flex items-center justify-center group-hover:bg-violet/20 transition-colors duration-300 border border-white/10 group-hover:border-violet/30">
                    <svg class="w-4 h-4 text-text-secondary group-hover:text-violet transition-colors" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                      <path d="M5 12h14M12 5l7 7-7 7"/>
                    </svg>
                  </div>
                </div>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>

    <!-- Pagination Dots -->
    <div class="carousel-pagination flex items-center justify-center gap-2 mt-8" data-testid="carousel-pagination">
      {cards.map((_, index) => (
        <button 
          class="pagination-dot w-2 h-2 rounded-full bg-white/20 transition-all duration-300 hover:bg-violet/50"
          data-index={index}
          aria-label={`Go to card ${index + 1}`}
        />
      ))}
    </div>

    <!-- Progress Bar -->
    <div class="carousel-progress mt-6 max-w-xs mx-auto h-1 bg-white/10 rounded-full overflow-hidden">
      <div class="progress-bar h-full bg-gradient-to-r from-violet to-rose rounded-full transition-all duration-300" style="width: 12.5%"></div>
    </div>
  </div>
</section>

<style>
  /* Parallax orb animations */
  .parallax-orb {
    will-change: transform;
    transition: transform 0.3s ease-out;
  }

  .orb-1 {
    animation: float-slow 20s ease-in-out infinite;
  }

  .orb-2 {
    animation: float-slow 25s ease-in-out infinite reverse;
  }

  .orb-3 {
    animation: pulse-glow 8s ease-in-out infinite;
  }

  @keyframes float-slow {
    0%, 100% { transform: translate(0, 0) scale(1); }
    25% { transform: translate(30px, -20px) scale(1.05); }
    50% { transform: translate(-20px, 30px) scale(0.95); }
    75% { transform: translate(20px, 20px) scale(1.02); }
  }

  @keyframes pulse-glow {
    0%, 100% { opacity: 0.3; transform: translate(-50%, -50%) scale(1); }
    50% { opacity: 0.6; transform: translate(-50%, -50%) scale(1.2); }
  }

  /* Floating particles */
  .particle {
    animation: particle-float 6s ease-in-out infinite;
  }

  @keyframes particle-float {
    0%, 100% { transform: translateY(0) scale(1); opacity: 0.4; }
    50% { transform: translateY(-30px) scale(1.5); opacity: 0.8; }
  }

  /* Card states */
  .carousel-card {
    opacity: 0;
    pointer-events: none;
    filter: blur(12px);
  }

  .carousel-card.active {
    opacity: 1;
    pointer-events: auto;
    filter: blur(0);
    z-index: 30;
  }

  .carousel-card.prev,
  .carousel-card.next {
    opacity: 0.7;
    pointer-events: auto;
    filter: blur(1px);
    z-index: 20;
  }

  .carousel-card.far-prev,
  .carousel-card.far-next {
    opacity: 0.3;
    filter: blur(3px);
    z-index: 10;
  }

  /* Active pagination dot */
  .pagination-dot.active {
    width: 24px;
    background: linear-gradient(135deg, var(--color-violet), var(--color-rose));
  }

  /* Card inner glow on active */
  .carousel-card.active .card-inner {
    box-shadow: 
      0 0 60px rgba(168, 85, 247, 0.15),
      0 0 100px rgba(251, 113, 133, 0.1),
      inset 0 1px 0 rgba(255, 255, 255, 0.1);
  }

  /* Navigation button pulse on autoplay */
  .carousel-nav.playing {
    animation: nav-pulse 3s ease-in-out infinite;
  }

  @keyframes nav-pulse {
    0%, 100% { box-shadow: 0 0 0 0 rgba(168, 85, 247, 0); }
    50% { box-shadow: 0 0 20px 4px rgba(168, 85, 247, 0.3); }
  }

  /* Touch/swipe feedback */
  .carousel-track.swiping {
    transition: none !important;
  }

  .carousel-track.swiping .carousel-card {
    transition: none !important;
  }
</style>

<script>
class CapabilitiesCarousel {
  private container: HTMLElement;
  private track: HTMLElement;
  private cards: HTMLElement[];
  private dots: HTMLElement[];
  private progressBar: HTMLElement;
  private prevBtn: HTMLElement;
  private nextBtn: HTMLElement;
  private currentIndex: number = 0;
  private autoplayInterval: ReturnType<typeof setInterval> | null = null;
  private isAutoPlaying: boolean = true;
  private touchStartX: number = 0;
  private touchEndX: number = 0;
  private isDragging: boolean = false;

  constructor(section: HTMLElement) {
    this.container = section;
    this.track = section.querySelector('.carousel-track') as HTMLElement;
    this.cards = Array.from(section.querySelectorAll('.carousel-card'));
    this.dots = Array.from(section.querySelectorAll('.pagination-dot'));
    this.progressBar = section.querySelector('.progress-bar') as HTMLElement;
    this.prevBtn = section.querySelector('.carousel-prev') as HTMLElement;
    this.nextBtn = section.querySelector('.carousel-next') as HTMLElement;

    this.init();
  }

  private init() {
    this.updateCarousel();
    this.bindEvents();
    this.startAutoplay();
    this.initParallax();
  }

  private bindEvents() {
    // Arrow navigation
    this.prevBtn?.addEventListener('click', () => this.navigate(-1));
    this.nextBtn?.addEventListener('click', () => this.navigate(1));

    // Dot navigation
    this.dots.forEach((dot, index) => {
      dot.addEventListener('click', () => this.goToSlide(index));
    });

    // Card click navigation
    this.cards.forEach((card, index) => {
      card.addEventListener('click', () => {
        if (!card.classList.contains('active')) {
          this.goToSlide(index);
        }
      });
    });

    // Keyboard navigation
    document.addEventListener('keydown', (e) => {
      if (!this.isInViewport()) return;
      if (e.key === 'ArrowLeft') this.navigate(-1);
      if (e.key === 'ArrowRight') this.navigate(1);
    });

    // Touch/Swipe support
    this.track.addEventListener('touchstart', (e) => this.handleTouchStart(e), { passive: true });
    this.track.addEventListener('touchmove', (e) => this.handleTouchMove(e), { passive: true });
    this.track.addEventListener('touchend', () => this.handleTouchEnd());

    // Mouse drag support
    this.track.addEventListener('mousedown', (e) => this.handleMouseDown(e));
    document.addEventListener('mousemove', (e) => this.handleMouseMove(e));
    document.addEventListener('mouseup', () => this.handleMouseUp());

    // Pause autoplay on hover
    this.container.addEventListener('mouseenter', () => this.pauseAutoplay());
    this.container.addEventListener('mouseleave', () => this.resumeAutoplay());

    // Pause when not visible
    document.addEventListener('visibilitychange', () => {
      if (document.hidden) {
        this.pauseAutoplay();
      } else {
        this.resumeAutoplay();
      }
    });
  }

  private handleTouchStart(e: TouchEvent) {
    this.touchStartX = e.touches[0].clientX;
    this.track.classList.add('swiping');
    this.pauseAutoplay();
  }

  private handleTouchMove(e: TouchEvent) {
    this.touchEndX = e.touches[0].clientX;
  }

  private handleTouchEnd() {
    this.track.classList.remove('swiping');
    const diff = this.touchStartX - this.touchEndX;
    const threshold = 50;

    if (Math.abs(diff) > threshold) {
      if (diff > 0) {
        this.navigate(1);
      } else {
        this.navigate(-1);
      }
    }
    this.resumeAutoplay();
  }

  private handleMouseDown(e: MouseEvent) {
    this.isDragging = true;
    this.touchStartX = e.clientX;
    this.track.classList.add('swiping');
    this.pauseAutoplay();
  }

  private handleMouseMove(e: MouseEvent) {
    if (!this.isDragging) return;
    this.touchEndX = e.clientX;
  }

  private handleMouseUp() {
    if (!this.isDragging) return;
    this.isDragging = false;
    this.track.classList.remove('swiping');
    
    const diff = this.touchStartX - this.touchEndX;
    const threshold = 50;

    if (Math.abs(diff) > threshold) {
      if (diff > 0) {
        this.navigate(1);
      } else {
        this.navigate(-1);
      }
    }
    this.resumeAutoplay();
  }

  private navigate(direction: number) {
    const total = this.cards.length;
    this.currentIndex = (this.currentIndex + direction + total) % total;
    this.updateCarousel();
  }

  private goToSlide(index: number) {
    this.currentIndex = index;
    this.updateCarousel();
  }

  private updateCarousel() {
    const total = this.cards.length;
    const isMobile = window.innerWidth < 768;
    const cardWidth = isMobile ? 300 : 400;
    const gap = isMobile ? 40 : 80;

    this.cards.forEach((card, index) => {
      // Calculate relative position from current
      let relativeIndex = index - this.currentIndex;
      
      // Normalize to [-total/2, total/2]
      if (relativeIndex > total / 2) relativeIndex -= total;
      if (relativeIndex < -total / 2) relativeIndex += total;

      // Position cards in horizontal line with depth
      const translateX = relativeIndex * (cardWidth * 0.65 + gap);
      const absRel = Math.abs(relativeIndex);
      
      // Z-depth: active card at front, others progressively behind
      const translateZ = -absRel * 120;
      
      // Scale: active card full size, others progressively smaller
      const scale = Math.max(0.6, 1 - absRel * 0.15);
      
      // Rotation: slight rotation for depth effect
      const rotateY = relativeIndex * 8;

      card.style.transform = `
        translateX(${translateX}px)
        translateZ(${translateZ}px)
        rotateY(${rotateY}deg)
        scale(${scale})
      `;

      // Apply state classes
      card.classList.remove('active', 'prev', 'next', 'far-prev', 'far-next');
      
      if (relativeIndex === 0) {
        card.classList.add('active');
      } else if (relativeIndex === -1) {
        card.classList.add('prev');
      } else if (relativeIndex === 1) {
        card.classList.add('next');
      } else if (relativeIndex < -1) {
        card.classList.add('far-prev');
      } else {
        card.classList.add('far-next');
      }
    });

    // Update pagination dots
    this.dots.forEach((dot, index) => {
      dot.classList.toggle('active', index === this.currentIndex);
    });

    // Update progress bar
    const progress = ((this.currentIndex + 1) / total) * 100;
    this.progressBar.style.width = `${progress}%`;
  }

  private startAutoplay() {
    if (this.autoplayInterval) return;
    this.isAutoPlaying = true;
    this.nextBtn?.classList.add('playing');
    this.autoplayInterval = setInterval(() => {
      this.navigate(1);
    }, 4000);
  }

  private pauseAutoplay() {
    if (this.autoplayInterval) {
      clearInterval(this.autoplayInterval);
      this.autoplayInterval = null;
    }
    this.nextBtn?.classList.remove('playing');
  }

  private resumeAutoplay() {
    if (this.isAutoPlaying && !this.autoplayInterval) {
      this.startAutoplay();
    }
  }

  private isInViewport(): boolean {
    const rect = this.container.getBoundingClientRect();
    return rect.top < window.innerHeight && rect.bottom > 0;
  }

  private initParallax() {
    const orbs = this.container.querySelectorAll('.parallax-orb');
    
    window.addEventListener('scroll', () => {
      if (!this.isInViewport()) return;
      
      const scrolled = window.scrollY;
      const sectionTop = this.container.offsetTop;
      const relativeScroll = scrolled - sectionTop;
      
      orbs.forEach((orb, index) => {
        const speed = 0.1 + (index * 0.05);
        const yOffset = relativeScroll * speed;
        (orb as HTMLElement).style.transform = `translateY(${yOffset}px)`;
      });
    }, { passive: true });

    // Mouse parallax for orbs
    this.container.addEventListener('mousemove', (e) => {
      const rect = this.container.getBoundingClientRect();
      const x = (e.clientX - rect.left) / rect.width - 0.5;
      const y = (e.clientY - rect.top) / rect.height - 0.5;
      
      orbs.forEach((orb, index) => {
        const speed = 20 + (index * 10);
        const xOffset = x * speed;
        const yOffset = y * speed;
        (orb as HTMLElement).style.transform = `translate(${xOffset}px, ${yOffset}px)`;
      });
    });
  }
}

// Initialize
function initCarousels() {
  const sections = document.querySelectorAll('.capabilities-section');
  sections.forEach((section) => {
    new CapabilitiesCarousel(section as HTMLElement);
  });
}

// Run on load and Astro page transitions
document.addEventListener('astro:page-load', initCarousels);
if (document.readyState === 'loading') {
  document.addEventListener('DOMContentLoaded', initCarousels);
} else {
  initCarousels();
}
</script>
